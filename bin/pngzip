#!/bin/zsh

set -euo pipefail

readonly SCRIPT_NAME="pngzip"
readonly PNGQUANT_QUALITY="65-80"
readonly PNGQUANT_SPEED="1"

readonly GREEN=$'\033[0;32m'
readonly YELLOW=$'\033[1;33m'
readonly RED=$'\033[0;31m'
readonly NC=$'\033[0m'
typeset -ga COLLECTED_PNG_FILES=()

print_usage() {
  cat <<EOF
Usage:
  $SCRIPT_NAME <path...>
  $SCRIPT_NAME --help

Description:
  Accept one or more directories or PNG file paths.
  Directories are scanned recursively for PNG files.
  Running without arguments prints this help message.

Examples:
  $SCRIPT_NAME ./assets
  $SCRIPT_NAME ./assets ./images/a.png ./images/b.png
EOF
}

print_error() {
  echo "${RED}Error:${NC} $1" >&2
}

print_warning() {
  echo "${YELLOW}Warning:${NC} $1"
}

require_command() {
  local cmd="$1"

  if ! command -v "$cmd" >/dev/null 2>&1; then
    print_error "Missing dependency: $cmd"
    echo "Install it first: brew install $cmd" >&2
    exit 1
  fi
}

file_size() {
  stat -f%z "$1"
}

is_png_file() {
  local path="$1"
  [[ "${path:l}" == *.png ]]
}

append_png_from_directory() {
  local dir="$1"
  local found_any=0
  local found_file

  while IFS= read -r found_file; do
    [[ -z "$found_file" ]] && continue
    COLLECTED_PNG_FILES+=("$found_file")
    found_any=1
  done < <(/usr/bin/find "$dir" -type f \( -iname "*.png" \) | /usr/bin/sort)

  if (( found_any == 0 )); then
    print_warning "No PNG files found in directory: $dir"
  fi
}

collect_png_files() {
  local path
  COLLECTED_PNG_FILES=()

  for path in "$@"; do
    if [[ -d "$path" ]]; then
      append_png_from_directory "$path"
    elif [[ -f "$path" ]]; then
      if is_png_file "$path"; then
        COLLECTED_PNG_FILES+=("$path")
      else
        print_warning "Non-PNG file skipped: $path"
      fi
    else
      print_warning "Path does not exist, skipped: $path"
    fi
  done
}

format_bytes() {
  local bytes="$1"
  local abs_bytes="$bytes"
  local sign=""

  if (( bytes < 0 )); then
    abs_bytes=$(( -bytes ))
    sign="-"
  fi

  if (( abs_bytes >= 1048576 )); then
    printf '%s%.2fMB' "$sign" "$(awk "BEGIN { printf ${abs_bytes}/1048576 }")"
  elif (( abs_bytes >= 1024 )); then
    printf '%s%.2fKB' "$sign" "$(awk "BEGIN { printf ${abs_bytes}/1024 }")"
  else
    printf '%s%dB' "$sign" "$abs_bytes"
  fi
}

main() {
  local total_files=0
  local compressed_files=0
  local skipped_files=0
  local total_saved=0
  local file before after diff
  local -a png_files=()

  if (( $# == 0 )); then
    print_usage
    exit 0
  fi

  if (( $# == 1 )) && [[ "$1" == "-h" || "$1" == "--help" ]]; then
    print_usage
    exit 0
  fi

  require_command "pngquant"
  collect_png_files "$@"
  png_files=("${COLLECTED_PNG_FILES[@]}")

  echo "${GREEN}PNG Batch Compression${NC}"
  echo "Command: $SCRIPT_NAME"
  echo "Input paths: $*"

  if (( ${#png_files[@]} == 0 )); then
    echo "${YELLOW}No PNG files found${NC}"
    exit 0
  fi

  for file in "${png_files[@]}"; do
    (( total_files += 1 ))
    before=$(file_size "$file")

    if pngquant --quality="$PNGQUANT_QUALITY" --speed="$PNGQUANT_SPEED" --force --output "$file" -- "$file" >/dev/null 2>&1; then
      after=$(file_size "$file")
      diff=$(( before - after ))

      if (( diff > 0 )); then
        (( compressed_files += 1 ))
        (( total_saved += diff ))
        echo "  ✓ $(basename "$file")  Saved $(format_bytes "$diff")"
      else
        (( skipped_files += 1 ))
        echo "  - $(basename "$file")  No size gain, kept result"
      fi
    else
      (( skipped_files += 1 ))
      echo "  - $(basename "$file")  Compression failed, skipped"
    fi
  done

  echo "${GREEN}Done${NC}"
  echo "Processed files: $total_files"
  echo "Compressed files: $compressed_files"
  echo "Skipped files: $skipped_files"
  echo "Total saved: $(format_bytes "$total_saved")"
}

main "$@"
